# =============================================================================
# PDF Splitter – Tauri + Vue macOS Desktop App
# =============================================================================

# ── Rust / Cargo ─────────────────────────────────────────────────────────────
/target
src-tauri/target
_legacy/cli/target
Cargo.lock
**/*.rs.bk

# ── Node.js / npm ─────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Vite / Build outputs ──────────────────────────────────────────────────────
dist/
dist-ssr/
*.local

# ── Tauri ────────────────────────────────────────────────────────────────────
# Build output bundles (DMG, app bundle, etc.)
src-tauri/target/
# WiX toolset (Windows – not used here but exclude anyway)
*.wixobj
*.wixpdb

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# ── Editors / IDEs ───────────────────────────────────────────────────────────
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains / RustRover / WebStorm
.idea/
*.iml

# Zed
.zed/

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Test artifacts ───────────────────────────────────────────────────────────
coverage/
*.lcov
/test-results/

# ── Temporary / Misc ─────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
.cache/

# ── Legacy CLI (fully removed from the project) ──────────────────────────────
_legacy/

# ── Sample / test input files ─────────────────────────────────────────────────
input/

# ── Mobile platform icons (macOS-only desktop app) ───────────────────────────
src-tauri/icons/android/
src-tauri/icons/ios/

# ── Windows Store icons (not relevant for macOS desktop) ─────────────────────
src-tauri/icons/Square*Logo.png
src-tauri/icons/StoreLogo.png
